---
import Layout from '@/layouts/Layout.astro';
import Manufaktur from '@/components/Manufaktur.tsx';
---
<Layout title="Manufaktur - Schmidt Revolution">
  <section class="pt-16 container-x">
    <div class="eyebrow mb-5 flex items-center gap-3">
      <span class="h-px w-8 bg-schmidt-yellow"></span>
      Bad Segeberg · Seit 1995
    </div>
    <h1 class="h-display text-[56px] lg:text-[96px] leading-[0.92] text-white max-w-4xl">
      31 Jahre <br/>
      <span class="italic font-light text-schmidt-yellow">Manufaktur.</span>
    </h1>
  </section>
  <Manufaktur client:visible />

  <section class="container-x pb-32">
    <div class="grid lg:grid-cols-3 gap-4">
      {[
        { k: '10.000+', v: 'Fahrzeug-Anwendungen mit Gutachten' },
        { k: '120+', v: 'Zertifizierte Händler in DACH' },
        { k: '21 Tage', v: 'Lieferzeit auftragsbezogene Fertigung' },
        { k: '4 CNC', v: 'Bearbeitungszentren mit Live-Telemetrie' },
        { k: 'AlSi7', v: 'T6-Legierung - Luftfahrt-Standard' },
        { k: 'CARB', v: 'Zertifiziert für USA-Markt' },
      ].map((s) => (
        <div class="p-8 rounded-2xl border border-white/[0.06] bg-schmidt-carbon">
          <div class="font-display text-4xl text-white mb-3">{s.k}</div>
          <div class="text-sm text-schmidt-silver leading-relaxed">{s.v}</div>
        </div>
      ))}
    </div>
  </section>
</Layout>
