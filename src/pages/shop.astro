---
import Layout from '@/layouts/Layout.astro';
import { shopProducts, shopCategories } from '@/data/shop';
---
<Layout title="Original Zubehoer - Schmidt Shop">
  <section class="pt-16 container-x mb-12">
    <div class="eyebrow mb-5 flex items-center gap-3">
      <span class="h-px w-8 bg-schmidt-yellow"></span>
      Original Zubehoer & Pflege
    </div>
    <div class="grid lg:grid-cols-[1.4fr_1fr] gap-12 items-end">
      <h1 class="h-display text-[56px] lg:text-[88px] leading-[0.92] text-white">
        Mehr <span class="italic font-light text-schmidt-yellow">Moeglichkeiten</span> fuer deine Schmidt Felgen.
      </h1>
      <p class="text-base lg:text-lg text-schmidt-silver leading-relaxed">
        Passende Nabenkappen, Logos, Pflegeprodukte und Streetwear - alles offiziell. Versand werktags binnen 24h direkt aus Bad Segeberg.
      </p>
    </div>
  </section>

  {/* Category tiles */}
  <section class="container-x mb-16">
    <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-3 lg:gap-4">
      {shopCategories.map((c) => (
        <a href={`#${c.id.toLowerCase()}`} class="group relative p-6 rounded-2xl border border-white/[0.06] bg-schmidt-carbon hover:border-schmidt-yellow/40 transition-colors">
          <div class="font-display text-xl text-white mb-1">{c.label}</div>
          <div class="text-xs text-schmidt-silver mb-4">{c.description}</div>
          <div class="text-[11px] text-schmidt-yellow inline-flex items-center gap-1 opacity-0 group-hover:opacity-100 transition-opacity">
            Entdecken
            <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14M13 5l7 7-7 7"/></svg>
          </div>
        </a>
      ))}
    </div>
  </section>

  {/* Category sections */}
  <section class="container-x pb-32 space-y-20">
    {shopCategories.map((cat) => {
      const items = shopProducts.filter(p => p.category === cat.id);
      if (items.length === 0) return null;
      return (
        <div id={cat.id.toLowerCase()}>
          <div class="flex items-end justify-between mb-6">
            <div>
              <div class="eyebrow text-schmidt-yellow mb-2">{cat.description}</div>
              <h2 class="font-display text-3xl lg:text-4xl text-white">{cat.label}</h2>
            </div>
            <a href="#" class="text-xs text-schmidt-silver hover:text-white">Alle ansehen →</a>
          </div>
          <div class="grid grid-cols-2 lg:grid-cols-4 gap-4">
            {items.map((p) => (
              <div class="group relative bg-schmidt-carbon rounded-2xl border border-white/[0.06] overflow-hidden hover:border-schmidt-yellow/40 transition-colors">
                {p.tag && (
                  <span class="absolute top-3 left-3 z-10 bg-schmidt-yellow text-schmidt-ink text-[10px] font-medium uppercase tracking-wide px-2 py-1 rounded-full">{p.tag}</span>
                )}
                <div class="aspect-square relative overflow-hidden bg-white/[0.03]">
                  <img src={p.image} alt={p.name} class="absolute inset-0 w-full h-full object-contain p-6 transition-transform duration-700 group-hover:scale-105" style="mix-blend-mode: lighten; filter: brightness(1.05) contrast(1.05);" />
                </div>
                <div class="p-4 border-t border-white/[0.06]">
                  <div class="text-sm text-white mb-1 line-clamp-2 min-h-[40px]">{p.name}</div>
                  <div class="flex items-center justify-between mt-3">
                    <div class="text-sm font-medium text-white">{p.price.toFixed(2).replace('.',',')} €</div>
                    <button class="text-[10px] uppercase tracking-widest text-schmidt-yellow hover:underline" data-add-cart={p.slug}>+ Warenkorb</button>
                  </div>
                </div>
              </div>
            ))}
          </div>
        </div>
      );
    })}
  </section>

  <script>
    document.querySelectorAll('[data-add-cart]').forEach((b) => {
      b.addEventListener('click', () => {
        const c = Number(localStorage.getItem('schmidt_cart_count') ?? 0) + 1;
        localStorage.setItem('schmidt_cart_count', String(c));
        const el = document.getElementById('cart-count');
        if (el) el.textContent = String(c);
        (b as HTMLElement).textContent = '✓ Hinzugefuegt';
        setTimeout(() => { (b as HTMLElement).textContent = '+ Warenkorb'; }, 1500);
      });
    });
  </script>
</Layout>
