---
import Layout from '@/layouts/Layout.astro';
import UnifiedShop from '@/components/UnifiedShop.tsx';
---
<Layout title="Shop - Schmidt Revolution Premium Alufelgen & Zubehoer">
  <section class="relative pt-16 lg:pt-20 pb-4 overflow-hidden">
    <div class="absolute inset-0 grid-bg opacity-30"></div>
    <div class="absolute top-0 right-0 w-[500px] h-[500px] bg-schmidt-yellow/5 blur-[120px] rounded-full"></div>
    <div class="container-x relative">
      <div class="eyebrow mb-5 flex items-center gap-3">
        <span class="h-px w-8 bg-schmidt-yellow"></span>
        Schmidt Shop - Kollektion 2026
      </div>
      <h1 class="h-display text-[56px] lg:text-[88px] leading-[0.92] text-white max-w-4xl">
        Felgen, Zubehoer, <br/><span class="italic font-light text-schmidt-yellow">alles original.</span>
      </h1>
      <p class="text-base lg:text-lg text-schmidt-silver max-w-xl mt-6 leading-relaxed">
        23 Felgen-Modelle. 12+ Zubehoer-Produkte. Original Schmidt Streetwear. Versand werktags binnen 24h direkt aus Bad Segeberg.
      </p>
    </div>
  </section>
  <UnifiedShop client:load />
</Layout>
