---
import Layout from '@/layouts/Layout.astro';
import { galleryItems } from '@/data/gallery';

export function getStaticPaths() {
  return galleryItems.map(g => ({ params: { slug: g.slug }, props: { item: g } }));
}

const { item } = Astro.props as { item: typeof galleryItems[number] };
const related = galleryItems.filter(g => g.slug !== item.slug).slice(0, 3);
---
<Layout title={`${item.vehicle} - ${item.wheel} | Schmidt Galerie`}>
  <section class="relative h-[60vh] lg:h-[72vh] min-h-[420px] overflow-hidden">
    <img src={item.image} alt={item.title} class="absolute inset-0 w-full h-full object-cover" />
    <div class="absolute inset-0 bg-gradient-to-t from-schmidt-ink via-schmidt-ink/30 to-schmidt-ink/40"></div>
    <div class="container-x absolute inset-0 flex flex-col justify-end pb-16">
      <a href="/galerie" class="text-xs text-schmidt-silver hover:text-schmidt-yellow mb-6 inline-flex items-center gap-2 self-start">
        <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M19 12H5M11 19l-7-7 7-7"/></svg>
        Zurueck zur Galerie
      </a>
      <div class="eyebrow mb-3 flex items-center gap-2">
        <span class="text-schmidt-yellow">{item.date}</span>
        <span>·</span>
        <span>{item.dealer}</span>
      </div>
      <h1 class="h-display text-[40px] sm:text-[64px] lg:text-[88px] leading-[0.92] text-white max-w-5xl">
        {item.title}
      </h1>
    </div>
  </section>

  <section class="container-x pt-16 pb-32">
    <div class="grid lg:grid-cols-[1.4fr_1fr] gap-12 lg:gap-20">
      <div>
        <div class="eyebrow mb-4 text-schmidt-yellow">Infos zum Umbau</div>
        <p class="text-base lg:text-lg text-white leading-relaxed mb-8">{item.description}</p>

        <div class="rounded-2xl bg-schmidt-carbon border border-white/[0.06] p-6 lg:p-8 mb-8">
          <div class="eyebrow mb-4">Spec Sheet</div>
          <dl class="grid grid-cols-2 gap-x-8 gap-y-4 text-sm">
            <div>
              <dt class="text-schmidt-silver text-xs uppercase tracking-wide mb-1">Fahrzeug</dt>
              <dd class="text-white">{item.vehicle}</dd>
            </div>
            <div>
              <dt class="text-schmidt-silver text-xs uppercase tracking-wide mb-1">Felgenart</dt>
              <dd class="text-white">{item.wheel}</dd>
            </div>
            <div>
              <dt class="text-schmidt-silver text-xs uppercase tracking-wide mb-1">Groesse</dt>
              <dd class="text-white">{item.wheelSize}</dd>
            </div>
            <div>
              <dt class="text-schmidt-silver text-xs uppercase tracking-wide mb-1">Umgesetzt von</dt>
              <dd class="text-white">{item.dealer}</dd>
            </div>
          </dl>
        </div>

        <div class="flex flex-wrap gap-3">
          <a href="/konfigurator" class="btn-yellow text-sm">
            Aehnliche Konfiguration starten
            <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14M13 5l7 7-7 7"/></svg>
          </a>
          <a href="/haendler" class="btn-ghost text-sm">Haendler finden</a>
        </div>
      </div>

      <aside>
        <div class="sticky top-24 rounded-2xl bg-schmidt-carbon border border-white/[0.06] p-6">
          <div class="eyebrow mb-4 text-schmidt-yellow">Haendler-Profil</div>
          <div class="font-display text-2xl text-white mb-1">{item.dealer}</div>
          <div class="text-sm text-schmidt-silver mb-6">{item.dealerLocation}</div>

          <dl class="space-y-3 text-sm mb-6">
            <div class="flex justify-between border-b border-white/[0.06] pb-3">
              <dt class="text-schmidt-silver">Status</dt>
              <dd class="text-schmidt-yellow">Premium Partner</dd>
            </div>
            <div class="flex justify-between border-b border-white/[0.06] pb-3">
              <dt class="text-schmidt-silver">Schmidt-Linien</dt>
              <dd class="text-white text-right">FS · CC · TH · Modern</dd>
            </div>
            <div class="flex justify-between">
              <dt class="text-schmidt-silver">Sprachen</dt>
              <dd class="text-white">DE, EN</dd>
            </div>
          </dl>

          <a href="/haendler" class="block w-full btn-yellow justify-center py-3 text-sm">Termin anfragen</a>
        </div>
      </aside>
    </div>

    {/* Related */}
    <div class="mt-24 pt-12 border-t border-white/[0.06]">
      <div class="flex items-end justify-between mb-8">
        <h2 class="font-display text-3xl lg:text-4xl text-white">Weitere Umbauten</h2>
        <a href="/galerie" class="text-xs text-schmidt-yellow hover:underline">Alle ansehen →</a>
      </div>
      <div class="grid sm:grid-cols-3 gap-4">
        {related.map(r => (
          <a href={`/galerie/${r.slug}`} class="group relative aspect-[4/3] rounded-2xl overflow-hidden bg-schmidt-carbon border border-white/[0.06]">
            <img src={r.image} alt={r.title} class="absolute inset-0 w-full h-full object-cover transition-transform duration-700 group-hover:scale-105" />
            <div class="absolute inset-0 bg-gradient-to-t from-schmidt-ink/95 via-schmidt-ink/30 to-transparent"></div>
            <div class="absolute inset-0 p-4 flex flex-col justify-end">
              <div class="font-display text-base text-white">{r.vehicle}</div>
              <div class="text-[10px] text-schmidt-yellow">{r.wheel} · {r.wheelSize}</div>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>
</Layout>
