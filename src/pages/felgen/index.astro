---
import Layout from '@/layouts/Layout.astro';
import CatalogGrid from '@/components/CatalogGrid.tsx';
---
<Layout title="Felgen Katalog - Schmidt Revolution">
  <section class="relative pt-16 lg:pt-20 pb-8 overflow-hidden">
    <div class="absolute inset-0 grid-bg opacity-30"></div>
    <div class="absolute top-0 right-0 w-[500px] h-[500px] bg-schmidt-yellow/5 blur-[120px] rounded-full"></div>
    <div class="container-x relative">
      <div class="eyebrow mb-5 flex items-center gap-3">
        <span class="h-px w-8 bg-schmidt-yellow"></span>
        Kollektion 2026
      </div>
      <h1 class="h-display text-[56px] lg:text-[88px] leading-[0.92] text-white max-w-4xl">
        Alle Felgen. <span class="italic font-light text-schmidt-yellow">Alle</span> Bauarten.
      </h1>
      <p class="text-base lg:text-lg text-schmidt-silver max-w-xl mt-6 leading-relaxed">
        23 Modelle, 250+ Fahrzeug-Anwendungen, unzählige Konfigurationen. Filtere nach deinem Geschmack - oder lass den Konfigurator entscheiden.
      </p>
    </div>
  </section>
  <CatalogGrid client:load />
</Layout>
