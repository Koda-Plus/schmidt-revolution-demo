---
import Layout from '@/layouts/Layout.astro';
import DealerMap from '@/components/DealerMap.tsx';
---
<Layout title="Händler finden - Schmidt Revolution">
  <section class="pt-16 pb-8 container-x">
    <div class="eyebrow mb-5 flex items-center gap-3">
      <span class="h-px w-8 bg-schmidt-yellow"></span>
      Händler-Netzwerk
    </div>
    <h1 class="h-display text-[56px] lg:text-[80px] leading-[0.92] text-white max-w-3xl mb-6">
      Finde deinen <span class="italic font-light text-schmidt-yellow">Partner</span> in 30 Sekunden.
    </h1>
    <p class="text-base lg:text-lg text-schmidt-silver max-w-xl leading-relaxed">
      Über 120 zertifizierte Schmidt-Händler in Deutschland. Filtere nach Service-Art und Region - wir vermitteln dich an den passenden Partner.
    </p>
  </section>
  <div class="container-x pb-32">
    <DealerMap client:load />
  </div>
</Layout>
