  rel="noopener noreferrer"
  class="koda-badge fixed bottom-5 right-5 z-[100] inline-flex items-center gap-2.5 px-4 py-2.5 rounded-full backdrop-blur-xl text-xs font-medium transition-all duration-300 hover:-translate-y-0.5"
  style="background: #212721; border: 1px solid rgba(38, 208, 124, 0.4); color: #ffffff; box-shadow: 0 8px 32px -8px rgba(38, 208, 124, 0.3);"
>
  <span class="relative flex w-2 h-2">
    <span class="absolute inset-0 rounded-full animate-ping" style="background: #26D07C; opacity: 0.5;"></span>
    <span class="relative w-2 h-2 rounded-full" style="background: #26D07C;"></span>
  </span>
  <span class="hidden sm:inline tracking-[0.18em] uppercase text-[10px] text-white/70">Demo by</span>
  <span class="font-display text-[12px] tracking-tight">
    <span class="text-white">KODA</span><span style="color: #26D07C;">.PLUS</span>
  </span>
