---
const items = [
  { href: '/felgen', label: 'Felgen' },
  { href: '/konfigurator', label: 'Konfigurator' },
  { href: '/galerie', label: 'Galerie' },
  { href: '/shop', label: 'Shop' },
  { href: '/haendler', label: 'Händler' },
  { href: '/manufaktur', label: 'Manufaktur' },
];
const path = Astro.url.pathname;
---
<header class="fixed inset-x-0 top-0 z-50 backdrop-blur-xl bg-schmidt-ink/70 border-b border-white/[0.06]">
  <div class="container-x flex items-center justify-between h-16 lg:h-[72px]">
    <a href="/" class="flex items-center group">
      <img src="/scraped/logo.svg" alt="Schmidt Felgen" class="h-9 lg:h-10 w-auto" />
    </a>

    <nav class="hidden lg:flex items-center gap-1">
      {items.map((item) => (
        <a
          href={item.href}
          class:list={[
            'px-3.5 py-2 text-sm rounded-full transition-colors',
            path.startsWith(item.href)
              ? 'text-schmidt-yellow bg-white/5'
              : 'text-white/80 hover:text-white hover:bg-white/5'
          ]}
        >{item.label}</a>
      ))}
    </nav>

    <div class="flex items-center gap-2">
      <button
        id="open-cart"
        class="hidden md:inline-flex items-center gap-2 text-xs uppercase tracking-[0.18em] text-white/70 hover:text-white transition-colors px-3 py-2"
        aria-label="Warenkorb"
      >
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
          <path d="M6 6h15l-1.5 9H7.5L6 6Z"/><circle cx="9" cy="20" r="1.5"/><circle cx="18" cy="20" r="1.5"/><path d="M6 6L4 2H1"/>
        </svg>
        <span>Warenkorb <span class="text-schmidt-yellow font-medium" id="cart-count">0</span></span>
      </button>
      <a href="/konfigurator" class="btn-yellow text-xs px-4 py-2.5">
        Konfigurator starten
        <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14M13 5l7 7-7 7"/></svg>
      </a>
    </div>
  </div>
</header>
<div class="h-16 lg:h-[72px]"></div>
